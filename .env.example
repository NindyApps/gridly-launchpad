# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (GPT-4o-mini for signal classification)
OPENAI_API_KEY=

# HubSpot CRM Integration
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://your-domain.com/api/crm/hubspot/callback

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Resend Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=OCTOPILOT <noreply@yourdomain.com>

# Ingestion Engine (used for cron authentication)
CRON_SECRET=

# App URL (used for redirect links in emails and Stripe callbacks)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Salesforce CRM Integration
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://your-domain.com/api/crm/salesforce/callback

# Token Encryption (AES-GCM for HubSpot + Salesforce tokens stored in DB)
# Must be exactly 32 random characters. Generate: Math.random().toString(36).repeat(5).slice(0,32)
# Also add to Supabase Edge Function Secrets under the same name.
ENCRYPTION_KEY=
